@page
@model WebApplication1.Pages.AddArticleModel

<!DOCTYPE html>
<html>
<head>
        <title>Добавление статьи</title>
        <link rel="stylesheet" href="css/reset.css">
        <link rel="stylesheet" href="css/normalize.css">
        <link rel="stylesheet" href="css/style.css">
        <script src="~/ckeditor/ckeditor.js"></script>

    </head>
    <body>


    <header class="top_bar">
        <div class="website_name">
            <span class="eu">ЕВРО</span><span class="news">НОВОСТИ</span>
        </div>
    </header>


    <form method="post">
        @Html.AntiForgeryToken()
        <div class="add_article_container">

            <div class="left_block">
                <h3 class="add_article_info_text">Выберите категорию</h3>
                <select class="add_articel_select_box" id="theme" name="Theme" >
                    <option value="" selected disabled hidden></option>
                    <option value="Люди">Люди</option>
                    <option value="Авто">Авто</option>
                    <option value="Технологии">Технологии</option>
                    <option value="Недвижимость">Недвижимость</option>
                </select>
                <h3 class="add_article_info_text">Введите дату написания статьи</h3>
                <input class="add_article_date_input_box" type="text" name="Date"/>

                <h3 class="add_article_info_text">Введите заголовок статьи</h3>
                <textarea class="add_article_title_input_box" type="text" name="Title"></textarea>

                <h3 class="add_article_info_text">Вставьте ссылку на картинку, связанную с темо статьи</h3>
                <textarea class="add_article_title_input_box" type="text" name="ArticeImage"></textarea>
            </div>

            <div class="right_block">
                <h3 class="add_article_info_text">Введите текст статьи</h3>
                <div class="ckeditorarea">
                    <textarea id="editor" name="Text"></textarea>
                </div>
                <script>
                    CKEDITOR.replace("editor");
                </script>
            </div>
        </div>

        
        <button type="submit">Отправить</button>
        <br />
        <div class="universal_button">
            <a href="/Index" class="universal_button_text">Назад</a>
        </div>

    </form>
    </body>
</html>